#header
  margin-bottom: 2rem

.site-hero
  position: relative
  min-height: 320px
  border-radius: 24px
  overflow: hidden
  margin: 24px auto 32px
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 45%, #60a5fa 100%)
  box-shadow: 0 24px 60px rgba(15, 23, 42, .24)

.site-hero__overlay
  position: absolute
  inset: 0
  background: url('/css/images/banner.jpg') center/cover no-repeat
  opacity: .25

.site-hero__content
  position: relative
  z-index: 1
  max-width: 980px
  margin: 0 auto
  padding: 72px 24px 48px
  color: #fff
  text-align: center

.site-hero__eyebrow
  margin: 0 0 12px
  letter-spacing: .2em
  text-transform: uppercase
  font-size: 12px
  opacity: .8

.site-hero__title
  margin: 0
  font-size: 42px
  line-height: 1.1
  a
    color: #fff

.site-hero__subtitle
  margin: 14px 0 28px
  font-size: 16px
  opacity: .9

.site-nav
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 12px

#main-nav .main-nav-link, #main-nav .nav-icon, #sub-nav .nav-icon, .article-footer a
  border-radius: 999px

#main-nav .main-nav-link
  background: rgba(255,255,255,.16)
  color: #fff
  padding: 8px 16px
  backdrop-filter: blur(10px)

#sub-nav
  margin-top: 12px

.article-card
  background: #fff
  border: 1px solid rgba(148, 163, 184, .18)
  border-radius: 20px
  padding: 28px
  box-shadow: 0 14px 36px rgba(15, 23, 42, .06)
  margin-bottom: 24px

.article-title
  font-size: 28px

.article-entry
  color: #334155
  line-height: 1.85

.article-entry p
  margin-bottom: 1em

.article-footer
  display: flex
  flex-wrap: wrap
  gap: 8px
  align-items: center
  border-top: 1px solid rgba(148, 163, 184, .16)
  padding-top: 16px
  margin-top: 16px

#footer
  margin-top: 64px
  padding: 40px 0 56px
  background: #0f172a
  color: #cbd5e1
  text-align: center

#footer a
  color: #fff

.footer-note
  margin-top: 6px
  opacity: .7

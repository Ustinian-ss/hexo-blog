$block
  background: var(--bg-surface)
  border: 1px solid var(--border-light)
  border-radius: var(--radius-md)
  box-shadow: var(--shadow-md)

$block-caption
  display: inline-block
  margin: 0 0 12px
  padding: 6px 14px
  border-radius: var(--radius-full)
  background: var(--accent-bg)
  color: var(--accent)
  font-weight: 700
  font-size: 13px
  letter-spacing: .04em
  border: 1px solid var(--accent-border)

$base-style
  word-wrap: break-word

$logo-text
  color: var(--text-on-hero)
  text-decoration: none
  font-weight: 800

$nav-link
  display: inline-flex
  align-items: center
  justify-content: center
  min-height: 40px
  padding: 0 14px
  border-radius: var(--radius-full)
  color: var(--text-on-hero)
  text-decoration: none
  transition: background var(--transition-fast)
  &:hover
    background: rgba(255,255,255,.18)

$article-share-link
  display: inline-flex
  align-items: center
  justify-content: center
  min-width: 36px
  min-height: 36px
  border-radius: var(--radius-full)
  background: var(--bg-elevated)
  color: var(--text-secondary)
  transition: all var(--transition-fast)
  &:hover
    background: var(--accent)
    color: #fff

$code-block
  background: var(--code-bg)
  color: var(--code-fg)
  border-radius: var(--radius-md)

$line-numbers
  color: var(--code-line-num)

// ============================================================
// Global body
// ============================================================
body
  background: var(--bg)
  color: var(--text-primary)
  transition: background var(--transition-slow), color var(--transition-slow)

// ============================================================
// Header / Hero
// ============================================================
#header
  margin-bottom: 2rem

.site-hero
  position: relative
  min-height: 280px
  border-radius: var(--radius-xl)
  overflow: hidden
  margin: 24px auto 32px
  background: linear-gradient(170deg, var(--hero-from) 0%, var(--hero-mid) 42%, var(--hero-to) 100%)
  box-shadow: var(--shadow-hero)
  transition: background var(--transition-slow)

.site-hero__overlay
  position: absolute
  inset: 0
  background: url('/css/images/banner.jpg') center/cover no-repeat
  opacity: .18
  mix-blend-mode: soft-light

.site-hero__content
  position: relative
  z-index: 1
  max-width: 980px
  margin: 0 auto
  padding: 60px 24px 42px
  color: var(--text-on-hero)
  text-align: center

.site-hero__eyebrow
  margin: 0 0 10px
  letter-spacing: .24em
  text-transform: uppercase
  font-size: 11px
  opacity: .78

.site-hero__title
  margin: 0
  font-size: clamp(34px, 6vw, 54px)
  line-height: 1.06
  letter-spacing: -.02em
  a
    color: var(--text-on-hero)
    text-decoration: none

.site-hero__subtitle
  margin: 14px 0 0
  font-size: 16px
  opacity: .82

.site-nav
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 12px
  margin-top: 24px

#main-nav .main-nav-link, #main-nav .nav-icon, #sub-nav .nav-icon, .article-footer a
  border-radius: var(--radius-full)

#main-nav .main-nav-link
  background: rgba(255,255,255,.12)
  color: var(--text-on-hero)
  padding: 9px 18px
  border: 1px solid rgba(255,255,255,.08)
  backdrop-filter: blur(12px)
  transition: all var(--transition-fast)
  &:hover
    background: rgba(255,255,255,.22)
    border-color: rgba(255,255,255,.18)
    transform: translateY(-1px)

#sub-nav
  margin-top: 12px

// ============================================================
// Dark mode toggle button
// ============================================================
.theme-toggle
  display: inline-flex
  align-items: center
  justify-content: center
  width: 38px
  height: 38px
  border-radius: var(--radius-full)
  background: rgba(255,255,255,.12)
  border: 1px solid rgba(255,255,255,.08)
  color: var(--text-on-hero)
  cursor: pointer
  transition: all var(--transition-fast)
  backdrop-filter: blur(12px)
  &:hover
    background: rgba(255,255,255,.22)
  .fa-sun-o
    display: none
  .fa-moon-o
    display: inline
  [data-theme="dark"] &
    .fa-sun-o
      display: inline
    .fa-moon-o
      display: none

// ============================================================
// Home shell layout
// ============================================================
.home-shell
  display: grid
  grid-template-columns: minmax(0, 1.8fr) minmax(280px, .9fr)
  gap: 26px
  align-items: start

.home-main
  min-width: 0

.home-sidebar
  position: sticky
  top: 18px
  display: grid
  gap: 18px

// ============================================================
// Card panel (glass)
// ============================================================
.card-panel
  background: var(--bg-surface)
  border: 1px solid var(--border)
  border-radius: var(--radius-lg)
  padding: 24px
  box-shadow: var(--shadow-sm)
  transition: box-shadow var(--transition-base), border-color var(--transition-base)
  &:hover
    box-shadow: var(--shadow-md)
    border-color: var(--accent-border)

// ============================================================
// Home intro
// ============================================================
.home-intro
  display: flex
  justify-content: space-between
  align-items: flex-end
  gap: 20px
  margin-bottom: 22px

.section-kicker
  margin: 0 0 8px
  color: var(--text-muted)
  font-size: 12px
  letter-spacing: .2em
  text-transform: uppercase
  font-weight: 600

.home-intro__title
  margin: 0
  font-size: 32px
  letter-spacing: -.02em
  color: var(--text-primary)

.home-intro__desc
  margin: 10px 0 0
  color: var(--text-secondary)
  line-height: 1.8

.home-stats
  display: flex
  gap: 10px
  flex-wrap: wrap
  justify-content: flex-end

.stat-pill
  min-width: 84px
  padding: 12px 16px
  border-radius: var(--radius-md)
  background: var(--bg-elevated)
  border: 1px solid var(--border)
  text-align: center
  transition: transform var(--transition-fast), box-shadow var(--transition-fast)
  &:hover
    transform: translateY(-2px)

// ============================================================
// Search dialog
// ============================================================
#search-mask
  position: fixed
  inset: 0
  z-index: 9998
  background: rgba(0,0,0,.5)
  opacity: 0
  visibility: hidden
  transition: all var(--transition-base)
  &.active
    opacity: 1
    visibility: visible

#search-dialog
  position: fixed
  top: 50%
  left: 50%
  transform: translate(-50%,-50%) scale(.9)
  z-index: 9999
  width: 90%
  max-width: 600px
  background: var(--bg-surface)
  border-radius: var(--radius-xl)
  box-shadow: var(--shadow-lg)
  opacity: 0
  visibility: hidden
  transition: all var(--transition-base)
  &.active
    opacity: 1
    visibility: visible
    transform: translate(-50%,-50%) scale(1)

.search-dialog-inner
  padding: 24px

.search-header
  display: flex
  justify-content: space-between
  align-items: center
  margin-bottom: 16px

.search-title
  font-size: 18px
  font-weight: 700
  color: var(--text-primary)
  i
    margin-right: 8px
    color: var(--accent)

.search-close
  width: 32px
  height: 32px
  border-radius: var(--radius-full)
  background: var(--bg-elevated)
  border: none
  color: var(--text-secondary)
  cursor: pointer
  font-size: 16px
  display: inline-flex
  align-items: center
  justify-content: center
  transition: all var(--transition-fast)
  &:hover
    background: var(--bg-hover)
    color: var(--text-primary)

.search-input-wrap
  margin-bottom: 16px

.search-input
  width: 100%
  padding: 14px 18px
  border: 2px solid var(--border)
  border-radius: var(--radius-md)
  background: var(--bg-elevated)
  color: var(--text-primary)
  font-size: 16px
  outline: none
  transition: border-color var(--transition-fast)
  &:focus
    border-color: var(--accent)

.search-results
  max-height: 360px
  overflow-y: auto
  display: grid
  gap: 8px

.search-result-item
  display: block
  padding: 14px 16px
  border-radius: var(--radius-sm)
  background: var(--bg-elevated)
  border: 1px solid var(--border)
  text-decoration: none
  transition: all var(--transition-fast)
  strong
    display: block
    color: var(--text-primary)
    font-size: 15px
    margin-bottom: 4px
  p
    margin: 0
    color: var(--text-muted)
    font-size: 13px
    line-height: 1.5
  &:hover
    border-color: var(--accent-border)
    background: var(--bg-hover)
    strong
      color: var(--accent)

.search-empty
  display: none
  text-align: center
  padding: 32px 0
  color: var(--text-muted)
  font-size: 14px

// ============================================================
// Sidebar profile card (new)
// ============================================================
.card-profile
  text-align: center
  padding: 28px 20px

.profile-avatar
  margin-bottom: 14px

.avatar-placeholder
  width: 80px
  height: 80px
  border-radius: 50%
  background: linear-gradient(135deg, var(--accent), #a78bfa)
  color: #fff
  display: inline-grid
  place-items: center
  font-size: 32px
  box-shadow: 0 8px 24px rgba(79,70,229,.3)

.profile-name
  font-size: 22px
  font-weight: 800
  color: var(--text-primary)
  margin-bottom: 6px

.profile-desc
  font-size: 14px
  color: var(--text-muted)
  line-height: 1.6
  margin-bottom: 18px

.profile-stats
  display: flex
  justify-content: center
  gap: 12px
  margin-bottom: 16px

.profile-stat
  min-width: 72px
  padding: 10px 14px
  border-radius: var(--radius-md)
  background: var(--bg-elevated)
  border: 1px solid var(--border)
  text-align: center
  text-decoration: none
  transition: all var(--transition-fast)
  &:hover
    transform: translateY(-2px)
    box-shadow: var(--shadow-sm)
    border-color: var(--accent-border)
  strong
    display: block
    font-size: 22px
    font-weight: 800
    color: var(--text-primary)
    line-height: 1.2
  span
    display: block
    margin-top: 2px
    font-size: 11px
    color: var(--text-muted)
    font-weight: 500

.profile-social
  display: flex
  justify-content: center
  gap: 10px

.profile-social-icon
  display: inline-flex
  align-items: center
  justify-content: center
  width: 36px
  height: 36px
  border-radius: var(--radius-full)
  background: var(--bg-elevated)
  color: var(--text-secondary)
  text-decoration: none
  font-size: 16px
  transition: all var(--transition-fast)
  &:hover
    background: var(--accent)
    color: #fff
    transform: translateY(-2px)

// ============================================================
// Profile card (original home-shell)
// ============================================================
.profile-card
  display: flex
  gap: 16px
  align-items: center

.profile-card__avatar
  width: 56px
  height: 56px
  border-radius: 50%
  background: linear-gradient(135deg, var(--accent), #a78bfa)
  color: #fff
  display: grid
  place-items: center
  font-size: 24px
  font-weight: 700
  flex-shrink: 0

.profile-card h3
  margin: 0 0 4px
  font-size: 18px
  color: var(--text-primary)

.profile-card p
  margin: 0
  color: var(--text-secondary)
  font-size: 14px

// ============================================================
// Side cards
// ============================================================
.side-card p
  margin-bottom: 0
  color: var(--text-secondary)
  line-height: 1.8

.compact-list
  list-style: none
  margin: 0
  padding: 0
  display: grid
  gap: 8px

.compact-list a
  display: block
  padding: 10px 14px
  background: var(--bg-elevated)
  border-radius: var(--radius-sm)
  color: var(--text-primary)
  text-decoration: none
  border: 1px solid var(--border)
  transition: all var(--transition-fast)
  &:hover
    background: var(--bg-hover)
    border-color: var(--accent-border)
    color: var(--accent)
    transform: translateX(3px)

.tag-cloud-lite
  display: flex
  flex-wrap: wrap
  gap: 8px
  a
    padding: 8px 14px
    border-radius: var(--radius-full)
    background: var(--accent-bg)
    color: var(--accent)
    text-decoration: none
    border: 1px solid var(--accent-border)
    font-size: 13px
    font-weight: 600
    transition: all var(--transition-fast)
    &:hover
      background: var(--accent)
      color: #fff
      transform: translateY(-1px)

// ============================================================
// Post stream
// ============================================================
.post-stream
  display: grid
  gap: 22px

.article-card
  background: var(--bg-surface)
  border: 1px solid var(--border)
  border-radius: var(--radius-lg)
  padding: 32px
  box-shadow: var(--shadow-sm)
  transition: box-shadow var(--transition-base), border-color var(--transition-base), transform var(--transition-fast)
  &:hover
    box-shadow: var(--shadow-md)
    border-color: var(--accent-border)
    transform: translateY(-2px)

.article-title
  font-size: clamp(22px, 3.4vw, 32px)
  font-weight: 800
  letter-spacing: -.02em
  color: var(--text-primary)
  a
    color: inherit
    text-decoration: none

.article-entry
  color: var(--text-primary)
  line-height: 1.88

.article-entry p
  margin-bottom: 1.2em

.article-entry a
  color: var(--accent)
  text-decoration: none
  border-bottom: 1px solid var(--accent-border)
  transition: border-color var(--transition-fast)
  &:hover
    border-bottom-color: var(--accent)

// ============================================================
// Tables (important for the posts)
// ============================================================
.article-entry table
  width: 100%
  border-collapse: separate
  border-spacing: 0
  margin: 1.6em 0
  font-size: .94em
  border-radius: var(--radius-md)
  overflow: hidden
  border: 1px solid var(--table-border)
  box-shadow: var(--shadow-sm)
  th
    font-weight: 700
    background: var(--bg-elevated)
    color: var(--text-primary)
    padding: 12px 16px
    text-align: left
    border-bottom: 2px solid var(--border)
    font-size: .92em
  td
    padding: 10px 16px
    border-bottom: 1px solid var(--table-border)
    color: var(--text-primary)
  tr:last-child td
    border-bottom: none
  tr:nth-child(even) td
    background: var(--table-stripe)

// ============================================================
// Code blocks
// ============================================================
.article-entry code
  background: var(--bg-elevated)
  color: var(--accent)
  padding: 2px 7px
  border-radius: 6px
  font-size: .9em
  border: 1px solid var(--border)

.article-entry pre
  background: var(--code-bg)
  color: var(--code-fg)
  border-radius: var(--radius-md)
  padding: 22px 26px
  overflow-x: auto
  margin: 1.5em 0
  box-shadow: var(--shadow-md)
  code
    background: none
    color: inherit
    padding: 0
    border: none
    font-size: .88em
    line-height: 1.72

// ============================================================
// Blockquotes
// ============================================================
.article-entry blockquote
  margin: 1.5em 0
  padding: 16px 22px
  border-left: 4px solid var(--accent)
  background: var(--accent-bg)
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0
  color: var(--text-secondary)
  p
    margin: 0

// ============================================================
// Article footer
// ============================================================
.article-footer
  display: flex
  flex-wrap: wrap
  gap: 8px
  align-items: center
  border-top: 1px solid var(--border)
  padding-top: 18px
  margin-top: 18px

// ============================================================
// Footer
// ============================================================
#footer
  margin-top: 72px
  padding: 44px 0 60px
  background: var(--footer-bg)
  color: var(--footer-fg)
  text-align: center
  transition: background var(--transition-slow)

#footer a
  color: #fff
  text-decoration: none
  transition: opacity var(--transition-fast)
  &:hover
    opacity: .8

.footer-note
  margin-top: 8px
  opacity: .65
  font-size: 13px

// ============================================================
// Pagination
// ============================================================
#page-nav
  display: flex
  justify-content: center
  gap: 12px
  margin-top: 36px
  a, span
    display: inline-flex
    align-items: center
    justify-content: center
    min-width: 42px
    min-height: 42px
    border-radius: var(--radius-full)
    padding: 0 16px
    text-decoration: none
    transition: all var(--transition-fast)
  a
    background: var(--bg-surface)
    color: var(--text-primary)
    border: 1px solid var(--border)
    &:hover
      background: var(--accent)
      color: #fff
      border-color: var(--accent)
  .page-number.current
    background: var(--accent)
    color: #fff
    font-weight: 700

// ============================================================
// Responsive
// ============================================================
@media (max-width: 900px)
  .home-shell
    grid-template-columns: 1fr
  .home-sidebar
    position: static
  .home-intro
    flex-direction: column
    align-items: flex-start
  .home-stats
    justify-content: flex-start
  .site-hero
    border-radius: var(--radius-lg)
    margin: 12px auto 22px
    min-height: 220px
  .site-hero__content
    padding: 42px 18px 32px
  .article-card
    padding: 22px

// ============================================================
// Hero social icons
// ============================================================
.site-hero__social
  display: flex
  justify-content: center
  gap: 12px
  margin-top: 20px

.hero-social-icon
  display: inline-flex
  align-items: center
  justify-content: center
  width: 40px
  height: 40px
  border-radius: var(--radius-full)
  background: rgba(255,255,255,.12)
  border: 1px solid rgba(255,255,255,.08)
  color: var(--text-on-hero)
  font-size: 18px
  text-decoration: none
  transition: all var(--transition-fast)
  backdrop-filter: blur(12px)
  &:hover
    background: rgba(255,255,255,.28)
    transform: translateY(-2px)
    box-shadow: 0 8px 24px rgba(0,0,0,.2)

// ============================================================
// Scroll-down indicator
// ============================================================
.scroll-down
  margin-top: 18px
  text-align: center
  animation: scroll-bounce 2s ease-in-out infinite

.scroll-down-icon
  display: inline-block
  font-size: 22px
  color: var(--text-on-hero)
  opacity: .7

@keyframes scroll-bounce
  0%, 100%
    transform: translateY(0)
  50%
    transform: translateY(8px)

// ============================================================
// Rightside panel
// ============================================================
#rightside
  position: fixed
  right: 20px
  bottom: 60px
  z-index: 999

#rightside-inner
  display: flex
  flex-direction: column
  gap: 8px

.rightside-btn
  display: inline-flex
  align-items: center
  justify-content: center
  width: 42px
  height: 42px
  border-radius: var(--radius-full)
  background: var(--bg-surface)
  border: 1px solid var(--border)
  color: var(--text-secondary)
  cursor: pointer
  font-size: 16px
  box-shadow: var(--shadow-sm)
  transition: all var(--transition-fast)
  &:hover
    background: var(--accent)
    color: #fff
    border-color: var(--accent)
    transform: translateY(-2px)
    box-shadow: var(--shadow-md)

#go-up
  opacity: .7
  &:hover
    opacity: 1

// ============================================================
// Article cover image
// ============================================================
.article-cover
  margin: -12px -12px 20px
  border-radius: var(--radius-md) var(--radius-md) 0 0
  overflow: hidden
  img
    width: 100%
    height: auto
    display: block
    object-fit: cover
    max-height: 320px

// ============================================================
// Code copy button
// ============================================================
.code-copy-btn
  position: absolute
  top: 8px
  right: 12px
  padding: 4px 10px
  border-radius: 6px
  background: rgba(255,255,255,.1)
  border: 1px solid rgba(255,255,255,.15)
  color: var(--code-fg)
  font-size: 12px
  cursor: pointer
  opacity: 0
  transition: all var(--transition-fast)
  &:hover
    background: rgba(255,255,255,.2)

pre
  position: relative
  &:hover .code-copy-btn
    opacity: 1

// ============================================================

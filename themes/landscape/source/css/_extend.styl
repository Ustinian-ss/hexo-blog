$block
  background: #fff
  border: 1px solid rgba(148, 163, 184, .16)
  border-radius: 18px
  box-shadow: 0 12px 36px rgba(15, 23, 42, .06)

$block-caption
  display: inline-block
  margin: 0 0 12px
  padding: 6px 12px
  border-radius: 999px
  background: #eff6ff
  color: #1d4ed8
  font-weight: 700
  letter-spacing: .04em

$base-style
  word-wrap: break-word

$logo-text
  color: #fff
  text-decoration: none
  font-weight: 800

$nav-link
  display: inline-flex
  align-items: center
  justify-content: center
  min-height: 40px
  padding: 0 14px
  border-radius: 999px
  color: #fff
  text-decoration: none
  transition: all .2s ease
  &:hover
    background: rgba(255,255,255,.18)

$article-share-link
  display: inline-flex
  align-items: center
  justify-content: center
  min-width: 36px
  min-height: 36px
  border-radius: 999px
  background: #f8fafc
  color: #475569

$code-block
  background: #0f172a
  color: #e2e8f0
  border-radius: 16px

$line-numbers
  color: #64748b

#header
  margin-bottom: 2rem

.site-hero
  position: relative
  min-height: 260px
  border-radius: 28px
  overflow: hidden
  margin: 24px auto 32px
  background: linear-gradient(180deg, rgba(4,8,20,.98) 0%, rgba(15,23,42,.92) 46%, rgba(96,165,250,.55) 100%)
  box-shadow: 0 24px 60px rgba(15, 23, 42, .24)

.site-hero__overlay
  position: absolute
  inset: 0
  background: url('/css/images/banner.jpg') center/cover no-repeat
  opacity: .22
  mix-blend-mode: screen

.site-hero__content
  position: relative
  z-index: 1
  max-width: 980px
  margin: 0 auto
  padding: 56px 24px 38px
  color: #fff
  text-align: center

.site-hero__eyebrow
  margin: 0 0 10px
  letter-spacing: .22em
  text-transform: uppercase
  font-size: 11px
  opacity: .82

.site-hero__title
  margin: 0
  font-size: clamp(34px, 6vw, 52px)
  line-height: 1.08
  a
    color: #fff

.site-hero__subtitle
  margin: 12px 0 0
  font-size: 15px
  opacity: .86

.site-nav
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 12px
  margin-top: 22px

#main-nav .main-nav-link, #main-nav .nav-icon, #sub-nav .nav-icon, .article-footer a
  border-radius: 999px

#main-nav .main-nav-link
  background: rgba(255,255,255,.14)
  color: #fff
  padding: 8px 16px
  border: 1px solid rgba(255,255,255,.1)
  backdrop-filter: blur(10px)

#sub-nav
  margin-top: 12px

.home-shell
  display: grid
  grid-template-columns: minmax(0, 1.8fr) minmax(280px, .9fr)
  gap: 26px
  align-items: start

.home-main
  min-width: 0

.home-sidebar
  position: sticky
  top: 18px
  display: grid
  gap: 18px

.card-panel
  background: rgba(255,255,255,.92)
  border: 1px solid rgba(148, 163, 184, .18)
  border-radius: 22px
  padding: 22px
  box-shadow: 0 16px 40px rgba(15, 23, 42, .06)
  backdrop-filter: blur(12px)

.home-intro
  display: flex
  justify-content: space-between
  align-items: flex-end
  gap: 20px
  margin-bottom: 22px

.section-kicker
  margin: 0 0 8px
  color: #64748b
  font-size: 12px
  letter-spacing: .18em
  text-transform: uppercase

.home-intro__title
  margin: 0
  font-size: 30px

.home-intro__desc
  margin: 10px 0 0
  color: #475569
  line-height: 1.8

.home-stats
  display: flex
  gap: 10px
  flex-wrap: wrap
  justify-content: flex-end

.stat-pill
  min-width: 84px
  padding: 10px 14px
  border-radius: 18px
  background: #f8fafc
  border: 1px solid rgba(148, 163, 184, .14)
  text-align: center
  strong
    display: block
    font-size: 22px
    color: #0f172a
  span
    display: block
    margin-top: 2px
    font-size: 12px
    color: #64748b

.profile-card
  display: flex
  gap: 14px
  align-items: center

.profile-card__avatar
  width: 56px
  height: 56px
  border-radius: 50%
  background: linear-gradient(135deg, #ef4444, #f97316)
  color: #fff
  display: grid
  place-items: center
  font-size: 22px
  font-weight: 700

.profile-card h3
  margin: 0 0 4px

.profile-card p
  margin: 0
  color: #64748b

.side-card p
  margin-bottom: 0
  color: #475569
  line-height: 1.8

.compact-list
  list-style: none
  margin: 0
  padding: 0
  display: grid
  gap: 10px

.compact-list a
  display: block
  padding: 10px 12px
  background: #f8fafc
  border-radius: 14px
  color: #0f172a
  border: 1px solid rgba(148, 163, 184, .12)

.tag-cloud-lite
  display: flex
  flex-wrap: wrap
  gap: 10px
  a
    padding: 8px 12px
    border-radius: 999px
    background: #eff6ff
    color: #1d4ed8
    border: 1px solid rgba(59, 130, 246, .16)

.post-stream
  display: grid
  gap: 20px

.article-card
  background: #fff
  border: 1px solid rgba(148, 163, 184, .16)
  border-radius: 22px
  padding: 28px
  box-shadow: 0 14px 36px rgba(15, 23, 42, .06)

.article-title
  font-size: clamp(22px, 3.4vw, 30px)

.article-entry
  color: #334155
  line-height: 1.88

.article-entry p
  margin-bottom: 1em

.article-footer
  display: flex
  flex-wrap: wrap
  gap: 8px
  align-items: center
  border-top: 1px solid rgba(148, 163, 184, .16)
  padding-top: 16px
  margin-top: 16px

#footer
  margin-top: 64px
  padding: 40px 0 56px
  background: #0f172a
  color: #cbd5e1
  text-align: center

#footer a
  color: #fff

.footer-note
  margin-top: 6px
  opacity: .7

@media (max-width: 900px)
  .home-shell
    grid-template-columns: 1fr
  .home-sidebar
    position: static
  .home-intro
    flex-direction: column
    align-items: flex-start
  .home-stats
    justify-content: flex-start

<div id="rightside">
  <div id="rightside-inner">
    <button id="darkmode-toggle" class="rightside-btn" title="切换深色/浅色模式" onclick="var h=document.documentElement;var t=h.getAttribute('data-theme')==='dark'?'light':'dark';h.setAttribute('data-theme',t);localStorage.setItem('theme',t);var m=document.querySelector('meta[name=\"theme-color\"]');if(m)m.setAttribute('content',t==='dark'?'#0b1120':'#f8f7f4')">
      <i class="fas fa-adjust"></i>
    </button>
    <button id="go-up" class="rightside-btn" title="回到顶部" onclick="window.scrollTo({top:0,behavior:'smooth'})">
      <i class="fas fa-arrow-up"></i>
    </button>
  </div>
</div>
<div id="progress-bar"></div>
<script>
  (function(){
    var bar=document.getElementById('progress-bar');
    var ticking=false;
    window.addEventListener('scroll',function(){
      if(!ticking){requestAnimationFrame(function(){
        var st=document.documentElement.scrollTop||document.body.scrollTop;
        var sh=document.documentElement.scrollHeight-document.documentElement.clientHeight;
        if(sh>0){var pct=Math.min((st/sh)*100,100);bar.style.width=pct+'%';bar.classList.add('visible')}
        else{bar.classList.remove('visible')}
        ticking=false
      });ticking=true}
    },{passive:true})
  })()
</script>
<script>
  window.addEventListener('load',function(){
    setTimeout(function(){
      document.getElementById('loading-box').classList.add('loaded');
      setTimeout(function(){var lb=document.getElementById('loading-box');if(lb)lb.remove()},700)
    },400)
  })
</script>
<div id="search-mask"></div>
<div id="search-dialog">
  <div class="search-dialog-inner">
    <div class="search-header">
      <span class="search-title"><i class="fas fa-search"></i> 搜索文章</span>
      <button class="search-close"><i class="fas fa-times"></i></button>
    </div>
    <div class="search-input-wrap">
      <input type="text" class="search-input" placeholder="输入关键词搜�?..">
    </div>
    <div class="search-results"></div>
    <div class="search-empty">未找到相关内�?/div>
  </div>
</div>
<script>
  (function(){
    var searchData=null;
    var mask=document.getElementById('search-mask');
    var dialog=document.getElementById('search-dialog');
    var input=dialog.querySelector('.search-input');
    var results=dialog.querySelector('.search-results');
    var empty=dialog.querySelector('.search-empty');
    var closeBtn=dialog.querySelector('.search-close');
    function openSearch(){
      mask.classList.add('active');
      dialog.classList.add('active');
      document.body.style.overflow='hidden';
      if(!searchData){
        fetch('/search.xml').then(function(r){return r.text()}).then(function(xml){
          var parser=new DOMParser();
          var doc=parser.parseFromString(xml,'text/xml');
          var entries=doc.querySelectorAll('entry');
          searchData=[];
          entries.forEach(function(e){
            searchData.push({
              title:e.querySelector('title').textContent,
              url:e.querySelector('url').textContent,
              content:(e.querySelector('content').textContent||'').replace(/<[^>]+>/g,'').substring(0,300)
            })
          })
        }).catch(function(){searchData=[]})
      }
      setTimeout(function(){input.focus()},100)
    }
    function closeSearch(){
      mask.classList.remove('active');
      dialog.classList.remove('active');
      document.body.style.overflow='';
      input.value='';
      results.innerHTML='';
      empty.style.display='none'
    }
    function doSearch(q){
      if(!searchData||!q.trim()){results.innerHTML='';empty.style.display='none';return}
      var kw=q.trim().toLowerCase();
      var hits=searchData.filter(function(item){
        return item.title.toLowerCase().indexOf(kw)>-1||item.content.toLowerCase().indexOf(kw)>-1
      });
      if(hits.length===0){results.innerHTML='';empty.style.display='block';return}
      empty.style.display='none';
      results.innerHTML=hits.map(function(item){
        return '<a class=\"search-result-item\" href=\"'+item.url+'\"><strong>'+item.title+'</strong><p>'+item.content.substring(0,120)+'...</p></a>'
      }).join('')
    }
    document.querySelector('.nav-search-btn').addEventListener('click',function(e){e.preventDefault();openSearch()});
    mask.addEventListener('click',closeSearch);
    closeBtn.addEventListener('click',closeSearch);
    input.addEventListener('input',function(){doSearch(this.value)});
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeSearch()})
  })()
</script>
<script>
  (function(){
    document.querySelectorAll('.article-entry pre').forEach(function(pre){
      var btn=document.createElement('button');
      btn.className='code-copy-btn';
      btn.innerHTML='<i class="fas fa-copy"></i> 复制';
      btn.addEventListener('click',function(){
        var code=pre.querySelector('code')||pre;
        navigator.clipboard.writeText(code.textContent).then(function(){
          btn.innerHTML='<i class="fas fa-check"></i> 已复�?;
          btn.style.background='rgba(34,197,94,.2)';
          setTimeout(function(){btn.innerHTML='<i class="fas fa-copy"></i> 复制';btn.style.background=''},2000)
        }).catch(function(){
          btn.innerHTML='<i class="fas fa-times"></i> 失败';
          setTimeout(function(){btn.innerHTML='<i class="fas fa-copy"></i> 复制'},2000)
        })
      });
      pre.appendChild(btn)
    })
  })()
</script>


<script id="starfield-script">
(function(){
  var canvas = document.getElementById('starfield');
  if(!canvas)return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var ctx = canvas.getContext('2d');
  var DPR = Math.min(window.devicePixelRatio || 1, 2);
  var W=0,H=0,particles=[],mouse={x:-9999,y:-9999,active:false};
  var LINK_DIST=120,MOUSE_DIST=200,GRAV=0.045,FR=0.94;
  function size(){
    W=window.innerWidth;H=window.innerHeight;
    canvas.width=Math.floor(W*DPR);canvas.height=Math.floor(H*DPR);
    canvas.style.width=W+'px';canvas.style.height=H+'px';
    ctx.setTransform(DPR,0,0,DPR,0,0);
  }
  function rnd(a,b){return Math.random()*(b-a)+a}
  function dark(){return document.documentElement.getAttribute('data-theme')==='dark'}
  function palette(){
    if(dark())return [[129,140,248],[167,139,250],[99,102,241],[196,181,253],[226,232,255]];
    return [[79,70,229],[99,102,241],[139,92,246],[124,58,237],[91,33,178]];
  }
  function build(){
    var count=Math.round(W*H/14000);
    count=Math.max(60,Math.min(140,count));
    if(reduce)count=42;
    particles=[];
    var pal=palette();
    for(var i=0;i<count;i++){
      var c=pal[Math.floor(Math.random()*pal.length)];
      particles.push({
        x:rnd(0,W),y:rnd(0,H),
        vx:rnd(-0.25,0.25),vy:rnd(-0.25,0.25),
        r:rnd(0.8,2.4),
        b:c,
        base:rnd(0.25,0.6),
        amp:rnd(0.15,0.35),
        ph:rnd(0,Math.PI*2),
        tw:rnd(0.0008,0.0022)
      });
    }
  }
  size();build();
  var rt;
  window.addEventListener('resize',function(){clearTimeout(rt);rt=setTimeout(function(){size();build()},180)});
  window.addEventListener('mousemove',function(e){mouse.x=e.clientX;mouse.y=e.clientY;mouse.active=true});
  document.addEventListener('mouseleave',function(){mouse.active=false;mouse.x=-9999;mouse.y=-9999});
  window.addEventListener('touchmove',function(e){var t=e.touches[0];if(t){mouse.x=t.clientX;mouse.y=t.clientY;mouse.active=true}},{passive:true});
  window.addEventListener('touchend',function(){mouse.active=false;mouse.x=-9999;mouse.y=-9999});
  new MutationObserver(function(){
    var pal=palette();
    for(var i=0;i<particles.length;i++){
      var c=pal[Math.floor(Math.random()*pal.length)];
      particles[i].b=c;
    }
  }).observe(document.documentElement,{attributes:true,attributeFilter:['data-theme']});
  function rgba(b,a){return 'rgba('+b[0]+','+b[1]+','+b[2]+','+a+')'}
  var last=(typeof performance!=='undefined'?performance.now():Date.now());
  function draw(now){
    now=now||(typeof performance!=='undefined'?performance.now():Date.now());
    var dt=now-last;last=now;
    ctx.clearRect(0,0,W,H);
    var n=particles.length;
    for(var i=0;i<n;i++){
      var p=particles[i];
      if(mouse.active){
        var dx=mouse.x-p.x,dy=mouse.y-p.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<MOUSE_DIST&&d>0.1){
          var f=(1-d/MOUSE_DIST)*GRAV;
          p.vx+=(dx/d)*f;p.vy+=(dy/d)*f;
        }
      }
      p.vx*=FR;p.vy*=FR;
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<-30)p.x=W+30;if(p.x>W+30)p.x=-30;
      if(p.y<-30)p.y=H+30;if(p.y>H+30)p.y=-30;
      p.ph+=p.tw*dt;
    }
    ctx.lineWidth=1;
    for(var a=0;a<n;a++){
      var pa=particles[a];
      for(var b=a+1;b<n;b++){
        var pb=particles[b];
        var dx=pa.x-pb.x,dy=pa.y-pb.y,d2=dx*dx+dy*dy;
        if(d2<LINK_DIST*LINK_DIST){
          var d=Math.sqrt(d2);
          var al=(1-d/LINK_DIST)*0.16;
          ctx.strokeStyle=rgba(pa.b,al);
          ctx.beginPath();ctx.moveTo(pa.x,pa.y);ctx.lineTo(pb.x,pb.y);ctx.stroke();
        }
      }
    }
    if(mouse.active){
      for(var m=0;m<n;m++){
        var p=particles[m];
        var dx=mouse.x-p.x,dy=mouse.y-p.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<MOUSE_DIST){
          var al=(1-d/MOUSE_DIST)*0.28;
          ctx.strokeStyle=rgba(p.b,al);
          ctx.beginPath();ctx.moveTo(mouse.x,mouse.y);ctx.lineTo(p.x,p.y);ctx.stroke();
        }
      }
    }
    for(var k=0;k<n;k++){
      var p=particles[k];
      var tw=p.base+Math.sin(p.ph)*p.amp;
      if(tw<0)tw=0;if(tw>0.95)tw=0.95;
      var g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*2.6);
      g.addColorStop(0,rgba(p.b,tw*0.28));
      g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=g;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r*2.6,0,Math.PI*2);ctx.fill();
      ctx.fillStyle=rgba(p.b,tw);
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();
</script>

<header id="header">
  <div class="site-hero">
    <div class="site-hero__overlay"></div>
    <div class="site-hero__content">
      <p class="site-hero__eyebrow">Jingtaiblog</p>
      <h1 class="site-hero__title"><a href="<%- url_for() %>"><%= config.title %></a></h1>
      <% if (theme.subtitle || config.subtitle){ %>
        <p class="site-hero__subtitle"><%= theme.subtitle || config.subtitle %></p>
      <% } %>
      <nav id="main-nav" class="site-nav">
        <a id="main-nav-toggle" class="nav-icon"><i class="fas fa-bars"></i></a>
        <a class="main-nav-link nav-search-btn" href="javascript:void(0)" title="搜索">
          <i class="fas fa-search"></i>
        </a>
        <% for (var i in theme.menu){ %>
          <a class="main-nav-link" href="<%- url_for(theme.menu[i]) %>"><%= i %></a>
        <% } %>
      </nav>
      <div class="site-hero__social">
        <% if (theme.links) { %>
          <% for (const i in theme.links) {%>
            <a class="hero-social-icon" href="<%- url_for(theme.links[i]) %>" target="_blank" rel="noopener" title="<%= i %>">
              <i class="fab fa-<%= i %>"></i>
            </a>
          <% } %>
        <% } %>
        <% if (theme.rss){ %>
          <a class="hero-social-icon" href="<%- url_for(theme.rss) %>" title="RSS">
            <i class="fas fa-rss"></i>
          </a>
        <% } %>
      </div>
      <div class="scroll-down">
        <i class="fas fa-angle-down scroll-down-icon"></i>
      </div>
    </div>
  </div>
</header>
